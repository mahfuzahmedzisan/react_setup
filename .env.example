# - `VITE_ENVIRONMENT_MODE=production|development|local`
VITE_ENVIRONMENT_MODE=local

# Optional env config:

# - `VITE_FAVICON_API_URL` (optional)
# - `VITE_FAVICON_RESPONSE_PATH` (optional, default: `data.favicon`)
# - `VITE_FAVICON_CACHE_TTL_MS` (optional)
# If `VITE_FAVICON_API_URL` is not set, system stays in manual/fallback mode.

# API (required). Vite only exposes vars prefixed with VITE_
VITE_API_BASE_URL=http://localhost:8000/api/v1

VITE_AUTH_STRATEGY=bearer_memory

# Bearer token storage: session | local | memory
VITE_BEARER_TOKEN_STORAGE=session

VITE_AUTH_ME_PATH=/me

# VITE_AUTH_LOGOUT_PATH=/logout

# Roles:
# - single: user.role = "admin"
# - multi: user.roles = ["admin","seller"]
# VITE_ROLE_MODE=single
#
# Optional role policy overrides (JSON string). Example:
# VITE_ROLE_POLICY_JSON={"admin":{"fallback":"/admin/login","dashboard":"/admin"},"seller":{"fallback":"/seller/login","dashboard":"/seller"}}

# Login pages:
# - single: one login page for all roles (authed users redirect away from any login route)
# - multi: role-specific login pages (authed users redirect away only from their own role login page)
# VITE_LOGIN_MODE=single

# Logout:
# - single: always POST to VITE_AUTH_LOGOUT_PATH
# - multi: if role policy provides logoutPath for the current role, POST there; otherwise fallback to VITE_AUTH_LOGOUT_PATH
# VITE_LOGOUT_MODE=single

# Optional: automatic access-token refresh on 401 (requires API to return `refresh_token` on login
# and a refresh endpoint). If omitted or VITE_REFRESH_TOKEN_ENABLED is not true, refresh is disabled.
# VITE_REFRESH_TOKEN_ENABLED=false
# VITE_AUTH_REFRESH_PATH=/oauth/token
# VITE_REFRESH_TOKEN_BODY_KEY=refresh_token
