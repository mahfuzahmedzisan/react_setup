# API (required). Vite only exposes vars prefixed with VITE_
VITE_API_BASE_URL=http://localhost:8000/api/v1

VITE_AUTH_STRATEGY=bearer_memory

# Bearer token storage (Passport JSON only — no HttpOnly cookie from API):
# - session (default): survives hard refresh in this tab; cleared when tab closes
# - local: persists across tabs until logout (common SPA pattern; protect with CSP against XSS)
# - memory: never survives reload (strongest client-only isolation; worst UX)
VITE_BEARER_TOKEN_STORAGE=session

VITE_AUTH_ME_PATH=/me

# VITE_AUTH_LOGOUT_PATH=/logout
